# 默认与 Saleor 模式相同；也可显式使用 npm run dev:saleor / dev:yudao-full
# @see .env.saleor  .env.yudao-full

SHOPRO_VERSION=v2.4.1

SHOPRO_BASE_URL=http://api-dashboard.yudao.iocoder.cn
SHOPRO_TRIAL_BASE_URL=http://api-dashboard.yudao.iocoder.cn/trial
SHOPRO_DEV_BASE_URL=http://127.0.0.1:8010

SHOPRO_SALEOR_BFF=1
SHOPRO_UPLOAD_TYPE=server
SHOPRO_API_PATH=
SHOPRO_WEBSOCKET_PATH=/infra/ws
SHOPRO_DEV_PORT=3000
SHOPRO_STATIC_URL=http://test.yudao.iocoder.cn
SHOPRO_H5_URL=http://127.0.0.1:3000
SHOPRO_MPLIVE_ON=0
SHOPRO_TENANT_ID=1

# VoceChat（Saleor H5 客服，见 docker-compose.vocechat.yml）
SHOPRO_VOCECHAT_BASE_URL=http://127.0.0.1:3009
SHOPRO_VOCECHAT_HOST_ID=1
SHOPRO_VOCECHAT_AUTO_REG=true
SHOPRO_VOCECHAT_CONTACT_PAGE=/pages/public/richtext?title=联系客服
